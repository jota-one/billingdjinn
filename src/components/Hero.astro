---
import heroImg from '../assets/hero.jpg'
---
<section
  class="relative w-full min-h-[90vh] flex flex-col items-center justify-center text-center px-6 lg:px-16 py-16 md:py-32"
>
  <!-- Background Image -->
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: url(${heroImg.src})`}
  >
  </div>
  <div class="absolute inset-0 bg-black opacity-50"></div>

  <!-- Content -->
  <div class="relative z-10 text-white w-full pt-50 max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-bold leading-tight">
      Gérez vos factures simplement
    </h1>
    <p class="mt-6 text-lg md:text-xl text-white/80">
      ...pas comme ces débiles.
    </p>
  </div>
</section>

<script>
  // Masquer le CTA si l'utilisateur n'est pas authentifié
  const userJwt = sessionStorage.getItem('userJwt')
  const isAuthenticated = userJwt && userJwt.length > 0

  if (!isAuthenticated) {
    const ctaElement = document.getElementById('heroCta')
    if (ctaElement) {
      ctaElement.style.display = 'none'
    }
  }
</script>
